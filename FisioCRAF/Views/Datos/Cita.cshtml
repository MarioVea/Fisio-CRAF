@{ 
    Layout = "~/Views/Shared/_menu.cshtml";
}
    <link rel="stylesheet" href="~/Content/estilos.css">
    <link rel="stylesheet" href="~/Content/cita.css">
    <div class="enc">
        <div class="encabezado" id="encabezado">
            <h2>Cita</h2>
            <div class="buscador" id="buscador-wrap">
                <input id="buscador" type="text" placeholder="Ingrese el nombre del paciente">
                <ul id="listaResultados" class="resultados oculto"></ul>
                <button id="abrirModal">Buscar</button>
            </div>
        </div>
    </div>
        <form action="" class="form-Cita">
            <div class="datos1">
                <div class="dato">
                    <label for="nombrePaciente">Paciente</label>
                    <input type="hidden" id="id_Pac">
                    <input type="hidden" id="id_Cita">
                    <input type="hidden" id="Folio">
                    <input id="nombrePaciente" type="text" disabled>
                    <button id="buscar-Paciente">Buscar</button>
                </div>
                <div class="dato">
                    <label for="fisio">Fisioterapeuta</label>
                    <select id="id_Emp" required>
                        <option value="">Seleccione un fisio</option>
                    </select>
                </div>
            </div>
            <div class="datos2">
                <div class="dato">
                    <label for="Motivo_Cita">Motivo de la cita</label>
                    <textarea name="motivo" id="Motivo_Cita" required></textarea>
                </div>
                <div class="datos-horario">
                    <div class="dato">
                        <label for="Fecha_Cita">Fecha</label>
                        <input id="Fecha_Cita" type="date">
                    </div>
                    <div class="dato">
                        <label for="Hora_Cita">Hora</label>
                        <select id="Hora_Cita" required>
                            <option value="">Seleccione fisioterapeuta y fecha</option>
                        </select>
                    </div>
                    <div class="estado-opciones">
                        <label for="estado">Estado</label>
                        <div class="opciones-estado">
                            <div class="opcion">
                                <label for="atendido">Atendida</label>
                                <input id="atendido" name="Estatus_Cita" type="radio" value="1">
                            </div>

                            <div class="opcion">
                                <label for="pendiente">Pendiente</label>
                                <input type="radio" name="Estatus_Cita" id="pendiente" value="0">
                            </div>
                            <div class="opcion">
                                <label for="cancelada">Cancelada</label>
                                <input type="radio" name="Estatus_Cita" id="cancelada" value="2">
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            <div class="acciones">
                <button id="btnGuardar" type="button">Guardar Cita</button>
                <button type="button" id="btn-actualizar">Actualizar Cita</button>
                <button id="btn-Eliminar">Eliminar Cita</button>
                <button type="reset" id="btn-limpiar">Limpiar Datos</button>
            </div>
        </form>

        <div id="modalBusqueda" class="modal modal-oculto" role="dialog" aria-modal="true" aria-labelledby="tituloModal">
            <div class="modal-contenido">
                <div class="modal-encabezado">
                    <h3 id="tituloModal">Buscar Cita</h3>
                    <button type="button" id="cerrarModal" class="btn-cerrar" aria-label="Cerrar">&times;</button>
                </div>
                <div class="modal-cuerpo">
                    <div style="margin-bottom: 15px;">
                        <label><input type="radio" name="tipoBusquedaCita" value="nombre" checked> Por paciente</label>
                        <label style="margin-left: 15px;"><input type="radio" name="tipoBusquedaCita" value="fecha"> Por Rango de Fechas</label>
                    </div>
                    <div id="contenedorBusquedaNombre">
                        <input id="modalBuscador" type="text" placeholder="Ingrese el nombre del paciente" class="modal-input" style="width: 50%;">
                    </div>
                    <div id="contenedorBusquedaFecha" class="oculto">
                        <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 15px;">
                            <input type="date" id="modalFechaInicio" class="modal-input" style="width: auto;">
                            <span> a </span>
                            <input type="date" id="modalFechaFin" class="modal-input" style="width: auto;">
                            <button id="btnBuscarCitasFecha" type="button" style="padding: 5px 10px; border-radius: 5px; cursor: pointer; border: 1px solid black; background: #fff;">Buscar</button>
                        </div>
                    </div>
                    <div class="tabla-scroll">
                        <table class="tabla-resultados">
                            <thead>
                                <tr>
                                    <th>Folio</th>
                                    <th>Nombre</th>
                                    <th>Fecha</th>
                                    <th>Hora</th>
                                </tr>
                            </thead>
                            <tbody id="modalResultados"></tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-acciones">
                    <button type="button" id="btnAceptar" class="btn-primario">Aceptar</button>
                    <button type="button" id="btnCancelar" class="btn-secundario">Cancelar</button>
                </div>
            </div>
        </div>


        <div id="modalBusquedaPaciente" class="modal modal-oculto" role="dialog" aria-modal="true" aria-labelledby="tituloModal">
            <div class="modal-contenido">
                <div class="modal-encabezado">
                    <h3 id="tituloModal">Buscar paciente</h3>
                    <button type="button" id="cerrarModalPaciente" class="btn-cerrar" aria-label="Cerrar">&times;</button>
                </div>
                <div class="modal-cuerpo">
                    <input id="modalBuscadorPaciente" type="text" placeholder="Ingrese el nombre del paciente" class="modal-input">
                    <div class="tabla-scroll">
                        <table class="tabla-resultados">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Apellido Paterno</th>
                                    <th>Apellido Materno</th>
                                    <th>Telefono</th>
                                    <th>Fecha Nacimiento</th>
                                    <th>Genero</th>
                                </tr>
                            </thead>
                            <tbody id="modalResultadosPaciente"></tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-acciones">
                    <button type="button" id="btnAceptarPaciente" class="btn-primario">Aceptar</button>
                    <button type="button" id="btnCancelarPaciente" class="btn-secundario">Cancelar</button>
                </div>
            </div>
        </div>





    <script>

        const cerrarModalPaciente = document.getElementById("cerrarModalPaciente");
        const btnCancelarPaciente = document.getElementById("btnCancelarPaciente");
        const btnAceptarPaciente = document.getElementById("btnAceptarPaciente");
        const btnBuscarPaciente = document.getElementById("buscar-Paciente");
        const modalResultadosPaciente = document.getElementById("modalResultadosPaciente");
        const modalBuscadorPaciente = document.getElementById("modalBuscadorPaciente");
        let modalTimerIdPaciente;
        let pacienteSeleccionado = null;


        const buscador = document.getElementById("buscador");
        const listaResultados = document.getElementById("listaResultados");
        let timerId;

        const modalBuscador = document.getElementById("modalBuscador");
        let modalTimerId;
        const btnGuardar = document.getElementById("btnGuardar");
        const btnLimpiar = document.getElementById("btn-limpiar");
        const modal = document.getElementById("modalBusqueda");
        const modalPaciente = document.getElementById("modalBusquedaPaciente");
        const cerrarModal = document.getElementById("cerrarModal");
        const btnAceptar = document.getElementById("btnAceptar");
        const btnCancelar = document.getElementById("btnCancelar");
        const inputCita = document.getElementById("id_Cita");
        const inputFolio = document.getElementById("Folio");
        const inputPaciente = document.getElementById("id_Pac");
        const inputMotivo = document.getElementById("Motivo_Cita");
        const inputFecha = document.getElementById("Fecha_Cita");
        const inputHora = document.getElementById("Hora_Cita");
        const comboFisio = document.getElementById("id_Emp");
        const nombrePaciente = document.getElementById("nombrePaciente");
        const modalResultados = document.getElementById("modalResultados");
        const radioAtendido = document.getElementById("atendido");
        const radioPendiente = document.getElementById("pendiente");
        const radioCancelada = document.getElementById("cancelada");
        let citaSeleccionada = null;


        document.addEventListener("DOMContentLoaded", function() {
            obtenerFisios();
            const hoy = new Date();
            const anio = hoy.getFullYear();
            const mes = String(hoy.getMonth() + 1).padStart(2, "0");
            const dia = String(hoy.getDate()).padStart(2, "0");
            inputFecha.setAttribute("min", `${anio}-${mes}-${dia}`);
        });

        comboFisio.addEventListener("change", function() {
            cargarHorasDisponibles();
        });

        inputFecha.addEventListener("change", function() {
            cargarHorasDisponibles();
        });

        async function cargarHorasDisponibles() {
            const idEmp = comboFisio.value;
            const fecha = inputFecha.value;

            inputHora.innerHTML = '';

            if (!idEmp || !fecha) {
                const optDefault = document.createElement('option');
                optDefault.value = '';
                optDefault.textContent = 'Seleccione fisioterapeuta y fecha';
                inputHora.appendChild(optDefault);
                return;
            }

            const optCargando = document.createElement('option');
            optCargando.value = '';
            optCargando.textContent = 'Cargando horarios...';
            inputHora.appendChild(optCargando);

            try {
                const response = await fetch(`/Datos/obtenerHorasOcupadas?idEmp=${idEmp}&fecha=${fecha}`);
                const horasOcupadas = await response.json();

                const todasLasHoras = ['14:00', '15:00', '16:00', '17:00', '18:00', '19:00', '20:00'];
                const horasDisponibles = todasLasHoras.filter(h => !horasOcupadas.includes(h));

                inputHora.innerHTML = '';

                if (horasDisponibles.length === 0) {
                    const optNone = document.createElement('option');
                    optNone.value = '';
                    optNone.textContent = 'No hay horarios disponibles';
                    inputHora.appendChild(optNone);
                    return;
                }

                const optSeleccione = document.createElement('option');
                optSeleccione.value = '';
                optSeleccione.textContent = 'Seleccione una hora';
                inputHora.appendChild(optSeleccione);

                horasDisponibles.forEach(h => {
                    const opt = document.createElement('option');
                    opt.value = h;
                    const hora24 = parseInt(h.split(':')[0]);
                    const hora12 = hora24 > 12 ? hora24 - 12 : hora24;
                    const periodo = hora24 >= 12 ? 'PM' : 'AM';
                    opt.textContent = `${hora12}:00 ${periodo}`;
                    inputHora.appendChild(opt);
                });
            } catch (error) {
                inputHora.innerHTML = '';
                const optError = document.createElement('option');
                optError.value = '';
                optError.textContent = 'Error al cargar horarios';
                inputHora.appendChild(optError);
            }
        }

        if (btnLimpiar) {
            btnLimpiar.addEventListener("click", function() {
                limpiarFormulario();
            });
        }

        btnGuardar.addEventListener("click",async function(e){
            e.preventDefault();

            const datos = obtenerDatos();
            datos.Estatus_Cita = 1;

            if (!datos.Fecha_Cita || !datos.Hora_Cita || !datos.id_Emp || !datos.id_Pac) {
                alert("Por favor complete todos los campos requeridos (Paciente, Fisioterapeuta, Fecha y Hora).");
                return;
            }

            const hoyGuardar = new Date();
            hoyGuardar.setHours(0, 0, 0, 0);
            const fechaSeleccionada = new Date(datos.Fecha_Cita + "T00:00:00");
            if (fechaSeleccionada < hoyGuardar) {
                alert("No se puede agendar una cita en una fecha anterior a la actual.");
                return;
            }

            try {
                const response = await fetch(`/Datos/guardarCita`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(datos)
                })

                if (!response.ok) {
                    alert("Ocurri� un error con el servidor");
                    return;
                }

                const data = await response.json();

                if (data.respuesta == false) {
                    alert(data.mensaje || "Ocurri� un error al registrar la cita");
                }
                else if (data.respuesta == true) {
                    alert("Cita guardada exitosamente");
                    limpiarFormulario();
                }
            }
            catch (error) {
                alert(error.message);
            }
        
        });


        const btnActualizar = document.getElementById("btn-actualizar");
        btnActualizar.addEventListener("click", async function(e) {
            e.preventDefault();

            const datos = obtenerDatos();
            if (!datos.Fecha_Cita || !datos.Hora_Cita || !datos.id_Emp || !datos.id_Pac) {
                alert("Por favor complete todos los campos requeridos (Paciente, Fisioterapeuta, Fecha y Hora).");
                return;
            }

            const hoyActualizar = new Date();
            hoyActualizar.setHours(0, 0, 0, 0);
            const fechaSeleccionadaAct = new Date(datos.Fecha_Cita + "T00:00:00");
            if (fechaSeleccionadaAct < hoyActualizar) {
                alert("No se puede agendar una cita en una fecha anterior a la actual.");
                return;
            }

            try {
                const response = await fetch(`/Datos/actualizarCita`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(datos)
                })

                if (!response.ok) {
                    alert("Ocurri� un error con el servidor");
                    return;
                }

                const data = await response.json();

                if (data.respuesta == false) {
                    alert(data.mensaje || "Ocurri� un error al actualizar la cita");
                }
                else if (data.respuesta == true) {
                    alert("Cita actualizada exitosamente");
                    limpiarFormulario();
                }
            }
            catch (error) {
                alert(error.message);
            }
        });


        const btnEliminar = document.getElementById("btn-Eliminar");
        btnEliminar.addEventListener("click", async function(e) {
            e.preventDefault();

            const idCita = inputCita.value;
            if (!idCita) {
                alert("Seleccione una cita para eliminar.");
                return;
            }

            if (!confirm("�Est� seguro de que desea eliminar esta cita?")) {
                return;
            }

            try {
                const response = await fetch(`/Datos/eliminarCita`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ id_Cita: idCita })
                })

                if (!response.ok) {
                    alert("Ocurrió un error con el servidor");
                    return;
                }

                const data = await response.json();

                if (data.respuesta == false) {
                    alert("Ocurrió un error al eliminar la cita");
                }
                else if (data.respuesta == true) {
                    alert("Cita eliminada exitosamente");
                    limpiarFormulario();
                }
            }
            catch (error) {
                alert(error.message);
            }
        });


        buscador.addEventListener("input", function () {
            clearTimeout(timerId);
            timerId = setTimeout(() => {
                const valor = this.value.trim();
                if (!valor) {
                    mostrarResultados([]);
                    return;
                }
                let nombre = encodeURIComponent(valor);
                fetch(`/Datos/obtenerCitas?nombre=${nombre}`)
                    .then(response => response.json())
                    .then(data => {
                        mostrarResultados(data);
                    });
            }, 300);
        });

        function mostrarResultados(citas) {
            listaResultados.innerHTML = "";

            citas.forEach(c => {
                const item = document.createElement("li");
                item.textContent = `Folio: ${c.Folio || ""} | ${c.Nombre || ""} - ${formatearFecha(c.Fecha_Cita)} ${formatearHora(c.Hora_Cita)}`;
                item.addEventListener("click", function () {
                    asignarCita(c);
                    listaResultados.classList.add("oculto");
                    buscador.value = "";
                });
                listaResultados.appendChild(item);
            });

            if (listaResultados.children.length === 0) {
                listaResultados.classList.add("oculto");
            } else {
                listaResultados.classList.remove("oculto");
            }
        }

        modalBuscador.addEventListener("input", function () {
            clearTimeout(modalTimerId);
            modalTimerId = setTimeout(() => {
                const valor = this.value.trim();
                if (!valor) {
                    limpiarResultadosModal();
                    return;
                }
                let nombre = encodeURIComponent(valor);
                fetch(`/Datos/obtenerCitas?nombre=${nombre}`)
                    .then(response => response.json())
                    .then(data => {
                        mostrarResultadosModal(data);
                    });
            }, 300);
        });

        const radiosTipoBusqueda = document.querySelectorAll('input[name="tipoBusquedaCita"]');
        const contenedorBusquedaNombre = document.getElementById("contenedorBusquedaNombre");
        const contenedorBusquedaFecha = document.getElementById("contenedorBusquedaFecha");
        const btnBuscarCitasFecha = document.getElementById("btnBuscarCitasFecha");
        const modalFechaInicio = document.getElementById("modalFechaInicio");
        const modalFechaFin = document.getElementById("modalFechaFin");

        radiosTipoBusqueda.forEach(radio => {
            radio.addEventListener("change", function () {
                if (this.value === "nombre") {
                    contenedorBusquedaNombre.classList.remove("oculto");
                    contenedorBusquedaFecha.classList.add("oculto");
                } else {
                    contenedorBusquedaNombre.classList.add("oculto");
                    contenedorBusquedaFecha.classList.remove("oculto");
                }
                limpiarResultadosModal();
            });
        });

        btnBuscarCitasFecha.addEventListener("click", function () {
            const fInicio = modalFechaInicio.value;
            const fFin = modalFechaFin.value;

            if (!fInicio || !fFin) {
                alert("Por favor seleccione ambas fechas.");
                return;
            }

            fetch(`/Datos/obtenerCitasPorFecha?fechaInicio=${fInicio}&fechaFin=${fFin}`)
                .then(response => response.json())
                .then(data => {
                    mostrarResultadosModal(data);
                })
                .catch(err => {
                    alert("Error al buscar citas por fecha.");
                });
        });



        function mostrarResultadosModal(citas) {
            modalResultados.innerHTML = "";
            citaSeleccionada = null;

            citas.forEach(c => {
                const fila = document.createElement("tr");
                const celdaFolio = document.createElement("td");
                celdaFolio.textContent = c.Folio || "";
                const celdaNombre = document.createElement("td");
                celdaNombre.textContent = c.Nombre || "";
                const celdaFecha = document.createElement("td");
                celdaFecha.textContent = formatearFecha(c.Fecha_Cita);
                const celdaHora = document.createElement("td");
                celdaHora.textContent = formatearHora(c.Hora_Cita);

                fila.appendChild(celdaFolio);
                fila.appendChild(celdaNombre);
                fila.appendChild(celdaFecha);
                fila.appendChild(celdaHora);

                fila.addEventListener("click", function () {
                    Array.from(modalResultados.querySelectorAll("tr")).forEach(r => r.classList.remove("seleccionado"));
                    fila.classList.add("seleccionado");
                    citaSeleccionada = c;
                });

                modalResultados.appendChild(fila);
            });
        }

        function limpiarResultadosModal() {
            modalResultados.innerHTML = "";
            citaSeleccionada = null;
        }


        btnAceptarPaciente.addEventListener("click", function () {
            if (pacienteSeleccionado) {
                asignarPaciente(pacienteSeleccionado);
            }
            cerrarModalBusquedaPaciente();
        })

        btnAceptar.addEventListener("click", function () {
            if (citaSeleccionada) {
                asignarCita(citaSeleccionada);
            }
            cerrarModalBusqueda();
        })

        function obtenerDatos(){
                  
            const datos = {
                id_Cita : inputCita.value, 
                Folio : inputFolio.value, 
                id_Pac : inputPaciente.value, 
                Motivo_Cita : inputMotivo.value, 
                Fecha_Cita : inputFecha.value, 
                Hora_Cita : inputHora.value, 
                id_Emp : comboFisio.value, 
                Estatus_Cita : document.querySelector('input[name="Estatus_Cita"]:checked')?.value || "0"
            }


            return datos;
        }

        function limpiarFormulario() {
            inputCita.value = "";
            inputFolio.value = "";
            inputPaciente.value = "";
            nombrePaciente.value = "";
            inputMotivo.value = "";
            inputFecha.value = "";
            inputHora.innerHTML = '<option value="">Seleccione fisioterapeuta y fecha</option>';
            comboFisio.value = "";
            radioAtendido.checked = false;
            radioPendiente.checked = false;
            radioCancelada.checked = false;
            btnGuardar.disabled = false;
        }

        modalBuscadorPaciente.addEventListener("input", function () {
            clearTimeout(modalTimerIdPaciente);
            modalTimerIdPaciente = setTimeout(() => {
                const valor = this.value.trim();
                if (!valor) {
                    //limpiarResultadosModal();
                    return;
                }
                let nombre = encodeURIComponent(valor);
                fetch(`/Persona/buscarPacientes?nombre=${nombre}`)
                    .then(response => response.json())
                    .then(data => {
                        mostrarResultadosModalPaciente(data);
                    });
            }, 300);
        });

        function formatearFecha(valorFecha) {
            const ms = extraerTimestamp(valorFecha);
            if (!ms) {
                return "";
            }
            const fecha = new Date(ms);
            const dia = String(fecha.getDate()).padStart(2, "0");
            const mes = String(fecha.getMonth() + 1).padStart(2, "0");
            const anio = fecha.getFullYear();
            return `${dia}/${mes}/${anio}`;
        }


        function extraerTimestamp(valorFecha) {
            if (!valorFecha) {
                return null;
            }
            const match = /\/Date\((\d+)\)\//.exec(valorFecha);
            if (!match) {
                return null;
            }
            const ms = Number(match[1]);
            return Number.isFinite(ms) ? ms : null;
        }

        function formatearFechaInput(valorFecha) {
            const ms = extraerTimestamp(valorFecha);
            if (!ms) {
                return "";
            }
            const fecha = new Date(ms);
            const dia = String(fecha.getDate()).padStart(2, "0");
            const mes = String(fecha.getMonth() + 1).padStart(2, "0");
            const anio = fecha.getFullYear();
            return `${anio}-${mes}-${dia}`;
        }

        function formatearHora(valorHora) {
            if (!valorHora) {
                return "";
            }
            if (typeof valorHora === "string") {
                return valorHora.slice(0, 5);
            }
            const horas = String(valorHora.Hours ?? valorHora.hours ?? 0).padStart(2, "0");
            const minutos = String(valorHora.Minutes ?? valorHora.minutes ?? 0).padStart(2, "0");
            return `${horas}:${minutos}`;
        }


 
        async function obtenerFisios(){
            try{
                const response = await fetch(`/Datos/obtenerFisios`,{
                    method : "GET",
                    headers: {
                        "Content-Type" : "application/json"
                    }
                });

                if(!response.ok){
                    alert('Algo salio mal');
                    return;
                }
                const fisios = await response.json();
                fisios.forEach(fisio => {
                    const opcion = document.createElement('option');
                    opcion.value = fisio.id_Emp;
                    opcion.text = `${fisio.Nombre_Emp} ${fisio.ApellidoP_Emp} ${fisio.ApellidoM_Emp}`;
                    comboFisio.appendChild(opcion);
                }) 

            }
            catch(error){
                alert(error.message);
            }
            
        }


        abrirModal.addEventListener("click", function () {
        abrirModalBusqueda();
        });

        btnBuscarPaciente.addEventListener("click", function (e) {
            e.preventDefault();
            abrirModalBusquedaPaciente();
        });

        function abrirModalBusqueda() {
            modal.classList.remove("modal-oculto");
            modalBuscador.value = "";
            /*limpiarResultadosModal();*/
            pacienteSeleccionado = null;
            modalBuscador.focus();
        };
        function abrirModalBusquedaPaciente() {
            modalPaciente.classList.remove("modal-oculto");
            modalBuscador.value = "";
            //limpiarResultadosModal();
            pacienteSeleccionado = null;
            modalBuscador.focus();
        };
        
        btnCancelar.addEventListener("click", function () {
            cerrarModalBusqueda();
        });
        cerrarModal.addEventListener("click", function () {
            cerrarModalBusqueda();
        });
        btnCancelarPaciente.addEventListener("click", function () {
            cerrarModalBusquedaPaciente();
        });
        cerrarModalPaciente.addEventListener("click", function () {
            cerrarModalBusquedaPaciente();
        });

        function cerrarModalBusqueda() {
            modal.classList.add("modal-oculto");
        }
        function cerrarModalBusquedaPaciente() {
            modalPaciente.classList.add("modal-oculto");
        }



        function asignarPaciente(paciente) {
            inputPaciente.value = paciente.id_Pac || "";
            nombrePaciente.value = `${paciente.Nombre_Pac} ${paciente.ApellidoP_Pac} ${paciente.ApellidoM_Pac}`;
            

        }

        function asignarCita(cita) {
            inputCita.value = cita.id_Cita || "";
            inputFolio.value = cita.Folio || "";
            inputPaciente.value = cita.id_Pac || "";
            nombrePaciente.value = cita.Nombre || "";
            inputMotivo.value = cita.Motivo_Cita || "";
            inputFecha.value = formatearFechaInput(cita.Fecha_Cita);
            comboFisio.value = cita.id_Emp || "";

            // Cargar las horas disponibles y luego seleccionar la hora de la cita
            const horaFormateada = formatearHora(cita.Hora_Cita);
            cargarHorasDisponibles().then(() => {
                // Agregar la hora de la cita si no está disponible (ya está ocupada por esta misma cita)
                let encontrada = false;
                for (let i = 0; i < inputHora.options.length; i++) {
                    if (inputHora.options[i].value === horaFormateada) {
                        encontrada = true;
                        break;
                    }
                }
                if (!encontrada && horaFormateada) {
                    const opt = document.createElement('option');
                    opt.value = horaFormateada;
                    const hora24 = parseInt(horaFormateada.split(':')[0]);
                    const hora12 = hora24 > 12 ? hora24 - 12 : hora24;
                    const periodo = hora24 >= 12 ? 'PM' : 'AM';
                    opt.textContent = `${hora12}:00 ${periodo}`;
                    inputHora.appendChild(opt);
                }
                inputHora.value = horaFormateada;
            });

            const estatus = cita.Estatus_Cita;
            radioAtendido.checked = estatus === 1;
            radioPendiente.checked = estatus === 0;
            radioCancelada.checked = estatus === 2;

            btnGuardar.disabled = true;
        }



        function mostrarResultadosModalPaciente(pacientes) {
        modalResultados.innerHTML = "";
        pacienteSeleccionado = null;

        pacientes.forEach(p => {
            const fila = document.createElement("tr");
            const celdaNombre = document.createElement("td");
            celdaNombre.textContent = p.Nombre_Pac || "";
            const celdaPaterno = document.createElement("td");
            celdaPaterno.textContent = p.ApellidoP_Pac || "";
            const celdaMaterno = document.createElement("td");
            celdaMaterno.textContent = p.ApellidoM_Pac || "";
            const celdaTelefono = document.createElement("td");
            celdaTelefono.textContent = p.Telefono_Pac || "";
            const celdaFecha = document.createElement("td");
            celdaFecha.textContent = formatearFecha(p.Fecha_Nacimiento);
            const celdaGenero = document.createElement("td");
            celdaGenero.textContent = p.Genero || "";

            fila.appendChild(celdaNombre);
            fila.appendChild(celdaPaterno);
            fila.appendChild(celdaMaterno);
            fila.appendChild(celdaTelefono);
            fila.appendChild(celdaFecha);
            fila.appendChild(celdaGenero);

            fila.addEventListener("click", function () {
                Array.from(modalResultadosPaciente.querySelectorAll("tr")).forEach(r => r.classList.remove("seleccionado"));
                fila.classList.add("seleccionado");
                pacienteSeleccionado = p;
            });

            modalResultadosPaciente.appendChild(fila);
        });
    }

    </script>
