@{
    Layout = "~/Views/Shared/_menu.cshtml";
}



<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Diagnóstico — Fisioterapia</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/Content/diagnostico.css" />
</head>
<body>

    <!-- ═══════════════════════════════════════════
         HEADER
    ════════════════════════════════════════════ -->
    <header class="header">
        <h1>Diagnóstico</h1>

        <div class="search-wrap" role="search">
            <input id="search-global"
                   type="text"
                   placeholder="Ingrese el motivo de cita o nombre del paciente…"
                   autocomplete="off"
                   aria-label="Búsqueda de paciente" />
            <span class="icon" aria-hidden="true">🔍</span>
            <!-- Dropdown sugerencias -->
            <ul id="search-suggestions" class="suggestions-list" role="listbox" aria-label="Sugerencias"></ul>
        </div>

        <div class="header-actions">
            <button id="btn-limpiar" class="btn-secondary" type="button" title="Limpiar campos de paciente">🧹 Limpiar Datos</button>
            <button id="btn-eliminar" class="btn-danger" type="button" title="Eliminar registro">🗑️ Eliminar Registro</button>
            <button id="btn-save" class="btn-save" type="button" title="Guardar datos">💾 Guardar Datos</button>
        </div>
    </header>

    <!-- ═══════════════════════════════════════════
         MAIN
    ════════════════════════════════════════════ -->
    <main class="main" id="main-content">

        <!-- ── Campos superiores ── -->
        <section class="top-fields" aria-label="Datos del paciente y cita">

            <div class="field-group">
                <label for="motivo-cita">Motivo Cita</label>
                <input id="motivo-cita" type="text" placeholder="Ej. Dolor lumbar" maxlength="100" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" title="Solo texto" />
            </div>

            <div class="field-group">
                <label for="nombre-paciente">Nombre del Paciente</label>
                <input id="nombre-paciente" type="text" placeholder="Apellido, Nombre" maxlength="100" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s,]+" title="Solo letras" />
            </div>

            <div class="field-group">
                <label for="nombre-fisio">Nombre Fisioterapeuta</label>
                <input id="nombre-fisio" type="text" placeholder="Dr. / Dra." maxlength="100" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s.]+" title="Solo letras" />
            </div>

            <div class="field-group">
                <label for="consultorio">Consultorio</label>
                <select id="consultorio">
                    <option value="">— Seleccionar —</option>
                    <option value="1">Consultorio 1</option>
                    <option value="2">Consultorio 2</option>
                    <option value="3">Consultorio 3</option>
                </select>
            </div>

            <div class="field-group">
                <label for="num-diag">Núm. Diag</label>
                <input id="num-diag" type="number" value="1" min="1" readonly tabindex="-1" title="Consecutivo automático" />
            </div>

        </section>

        <!-- ── Pestañas ── -->
        <nav class="tabs" role="tablist" aria-label="Secciones del diagnóstico">
            <button class="tab active" role="tab" aria-selected="true" aria-controls="tab-datos" data-tab="datos">Datos Generales</button>
            <button class="tab" role="tab" aria-selected="false" aria-controls="tab-ejercicios" data-tab="ejercicios">Asignación de Ejercicios</button>
            <button class="tab" role="tab" aria-selected="false" aria-controls="tab-musculo" data-tab="musculo">Selección de Músculo</button>
        </nav>

        <!-- ══════════════════════════════
             TAB 1 — DATOS GENERALES
        ══════════════════════════════ -->
        <section id="tab-datos" class="tab-panel active" role="tabpanel" aria-labelledby="tab-datos-btn">

            <!-- Fila de opciones de diagnóstico -->
            <div class="dg-top">

                <fieldset class="tipo-diag">
                    <legend class="label">Tipo de Diagnóstico</legend>
                    <div class="radio-group">
                        <label><input type="radio" name="tipoDiag" value="generico" checked /> Genérico</label>
                        <label><input type="radio" name="tipoDiag" value="especifico" />        Específico</label>
                    </div>
                </fieldset>

                <div class="field-group">
                    <label for="nombre-diag">Nombre del Diagnóstico</label>
                    <input id="nombre-diag" type="text" placeholder="Ej. Tendinitis" maxlength="120" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ\s]+" title="Solo texto" />
                </div>

                <div class="field-group">
                    <label for="tipo-lesion">Tipo de Lesión</label>
                    <select id="tipo-lesion">
                        <option value="">— Seleccionar —</option>
                        <option value="muscular">Muscular</option>
                        <option value="ligamentosa">Ligamentosa</option>
                        <option value="osea">Ósea</option>
                        <option value="articular">Articular</option>
                        <option value="nerviosa">Nerviosa</option>
                    </select>
                </div>

                <div class="field-group">
                    <label for="sel-lesion">Selecciona una Lesión</label>
                    <select id="sel-lesion">
                        <option value="">— Seleccionar —</option>
                        <option value="desgarro">Desgarro</option>
                        <option value="esguince">Esguince</option>
                        <option value="fractura">Fractura</option>
                        <option value="contusion">Contusión</option>
                        <option value="luxacion">Luxación</option>
                    </select>
                </div>

            </div><!-- /dg-top -->
            <!-- Cuerpo: Radiografía | Escala | Descripción -->
            <div class="dg-body">

                <div class="xray-card">
                    <div class="card-head">📷 Radiografía</div>
                    <div class="card-body" id="xray-drop" role="button" tabindex="0" aria-label="Adjuntar radiografía">
                        <span id="xray-label">＋ Adjuntar imagen</span>
                        <img id="xray-preview" src="" alt="Vista previa radiografía" style="display:none; max-width:100%; max-height:150px;" />
                        <input id="xray-file" type="file" accept="image/*" style="display:none" aria-label="Seleccionar imagen de radiografía" />
                    </div>
                </div>

                <div class="pain-card">
                    <h3>ESCALA DE DOLOR</h3>
                    <div class="pain-emojis" role="radiogroup" aria-label="Escala de dolor">
                        <label class="pain-option">
                            <div class="emoji" aria-hidden="true">😁</div>
                            <input type="radio" name="dolor" value="0" aria-label="Sin dolor" />
                            <span>Sin Dolor</span>
                        </label>
                        <label class="pain-option">
                            <div class="emoji" aria-hidden="true">😐</div>
                            <input type="radio" name="dolor" value="1" aria-label="Dolor leve" />
                            <span>Leve</span>
                        </label>
                        <label class="pain-option">
                            <div class="emoji" aria-hidden="true">😟</div>
                            <input type="radio" name="dolor" value="2" aria-label="Dolor moderado" />
                            <span>Moderado</span>
                        </label>
                        <label class="pain-option">
                            <div class="emoji" aria-hidden="true">😣</div>
                            <input type="radio" name="dolor" value="3" aria-label="Dolor fuerte" />
                            <span>Fuerte</span>
                        </label>
                        <label class="pain-option">
                            <div class="emoji" aria-hidden="true">😭</div>
                            <input type="radio" name="dolor" value="4" aria-label="Dolor extremo" />
                            <span>Extremo</span>
                        </label>
                    </div>
                </div>

                <div class="desc-card">
                    <div class="card-head">📝 Descripción breve de la Lesión</div>
                    <textarea id="desc-lesion" placeholder="Describa brevemente los síntomas y hallazgos relevantes…" maxlength="500" aria-label="Descripción breve de la lesión"></textarea>
                </div>

            </div><!-- /dg-body -->
            <!-- Tabla de registros de diagnóstico -->
            <div class="table-wrap">
                <div class="table-head">
                    <button id="btn-add-diag" class="btn-add" type="button" title="Agregar registro de diagnóstico">＋</button>
                </div>
                <div class="table-scroll">
                    <table id="tabla-diag" aria-label="Registros de diagnóstico">
                        <thead>
                            <tr>
                                <th scope="col">Tipo de Diagnóstico</th>
                                <th scope="col">Nombre del Diagnóstico</th>
                                <th scope="col">Nombre de Lesión</th>
                                <th scope="col">Radiografía</th>
                                <th scope="col">Escala de Dolor</th>
                                <th scope="col">Descripción</th>
                                <th scope="col">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="diag-tbody">
                            <tr class="empty-row">
                                <td colspan="7">No hay registros. Presione ＋ para agregar.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </section><!-- /tab-datos -->
        <!-- ══════════════════════════════
             TAB 2 — ASIGNACIÓN DE EJERCICIOS
        ══════════════════════════════ -->
        <section id="tab-ejercicios" class="tab-panel" role="tabpanel" aria-labelledby="tab-ejercicios-btn">

            <div class="ej-top">
                <!-- Filtro de categorías tipo pills -->
                <div class="ej-filtros" role="group" aria-label="Filtrar por categoría">
                    <span class="filtro-label">Categoría:</span>
                    <button class="cat-pill active" data-cat="todos" type="button">Todos</button>
                    <button class="cat-pill" data-cat="movilidad" type="button">Movilidad</button>
                    <button class="cat-pill" data-cat="fuerza" type="button">Fuerza</button>
                    <button class="cat-pill" data-cat="estiramiento" type="button">Estiramiento</button>
                    <button class="cat-pill" data-cat="equilibrio" type="button">Equilibrio</button>
                    <button class="cat-pill" data-cat="respiratorio" type="button">Respiratorio</button>
                </div>

                <!-- Controles de ejercicio -->
                <div class="ej-controls">
                    <div class="field-group">
                        <label for="sel-ejercicio">Selecciona un Ejercicio</label>
                        <select id="sel-ejercicio" aria-label="Lista de ejercicios">
                            <option value="">— Seleccionar —</option>
                        </select>
                    </div>
                    <div class="field-group field-sm">
                        <label for="ej-series">Series</label>
                        <input id="ej-series" type="number" min="1" max="20" placeholder="0" title="Solo números enteros positivos" />
                    </div>
                    <div class="field-group field-sm">
                        <label for="ej-repeticiones">Repeticiones</label>
                        <input id="ej-repeticiones" type="number" min="1" max="100" placeholder="0" title="Solo números enteros positivos" />
                    </div>
                    <button id="btn-add-ej" class="btn-add" type="button" title="Agregar ejercicio">＋</button>
                </div>
            </div>

            <div class="table-wrap">
                <div class="table-scroll">
                    <table id="tabla-ejercicios" aria-label="Ejercicios asignados">
                        <thead>
                            <tr>
                                <th scope="col">Ejercicios Asignados</th>
                                <th scope="col">Categoría</th>
                                <th scope="col">Series</th>
                                <th scope="col">Repeticiones</th>
                                <th scope="col">Acción</th>
                            </tr>
                        </thead>
                        <tbody id="ej-tbody">
                            <tr class="empty-row">
                                <td colspan="5">No hay ejercicios asignados.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </section><!-- /tab-ejercicios -->
        <!-- ══════════════════════════════
             TAB 3 — SELECCIÓN DE MÚSCULO
        ══════════════════════════════ -->
        <section id="tab-musculo" class="tab-panel" role="tabpanel" aria-labelledby="tab-musculo-btn">

            <div class="musculo-layout">

                <!-- Panel izquierdo: cuerpo + controles -->
                <div class="musculo-left">

                    <!-- Selector género -->
                    <div class="genero-selector" role="group" aria-label="Seleccionar modelo de cuerpo">
                        <button class="genero-btn active" data-genero="masculino" type="button">♂ Masculino</button>
                        <button class="genero-btn" data-genero="femenino" type="button">♀ Femenino</button>
                    </div>

                    <!-- Vista anterior / posterior -->
                    <div class="vistas-selector" role="group" aria-label="Vista del cuerpo">
                        <button class="vista-btn active" data-vista="anterior" type="button">Vista Anterior</button>
                        <button class="vista-btn" data-vista="posterior" type="button">Vista Posterior</button>
                    </div>

                    <!-- Cuerpo SVG interactivo -->
                    <div class="body-canvas" id="body-canvas" aria-label="Cuerpo humano interactivo. Haga clic en un músculo para seleccionarlo.">
                        <!-- SVG se inyecta por JavaScript -->
                    </div>

                    <!-- Leyenda de zonas -->
                    <div class="zona-leyenda" id="zona-leyenda" aria-live="polite">
                        <span class="leyenda-dot" style="background:var(--teal)"></span>
                        <span id="zona-nombre-texto">Ninguna zona seleccionada</span>
                    </div>

                </div><!-- /musculo-left -->
                <!-- Panel derecho: tratamientos + descripción + tabla -->
                <div class="musculo-right">

                    <div class="musculo-form">

                        <div class="field-group">
                            <label for="zona-sel-display">Zona Seleccionada</label>
                            <input id="zona-sel-display" type="text" readonly placeholder="Haga clic en el cuerpo…" aria-label="Zona muscular seleccionada" />
                        </div>

                        <div class="field-group">
                            <label for="tratamiento-select">Tratamiento(s)</label>
                            <select id="tratamiento-select" multiple size="5" aria-label="Seleccionar tratamientos (puede elegir varios)">
                                <option value="electroterapia">Electroterapia</option>
                                <option value="ultrasonido">Ultrasonido terapéutico</option>
                                <option value="termoterapia">Termoterapia</option>
                                <option value="crioterapia">Crioterapia</option>
                                <option value="masaje">Masaje terapéutico</option>
                                <option value="movilizacion">Movilización articular</option>
                                <option value="acupuntura">Acupuntura</option>
                                <option value="kinesiotaping">Kinesiotaping</option>
                                <option value="hidroterapia">Hidroterapia</option>
                                <option value="ejercicio-terapeutico">Ejercicio terapéutico</option>
                            </select>
                            <small class="hint">Mantenga Ctrl / Cmd para seleccionar varios</small>
                        </div>

                        <div class="field-group">
                            <label for="musculo-desc">Descripción breve de la lesión</label>
                            <textarea id="musculo-desc" rows="4" maxlength="400" placeholder="Describa la lesión en esta zona…" aria-label="Descripción de lesión muscular"></textarea>
                        </div>

                        <button id="btn-add-musculo" class="btn-add-musculo" type="button">＋ Agregar zona</button>

                    </div>

                    <!-- Tabla de zonas agregadas -->
                    <div class="table-wrap" style="margin-top:16px">
                        <div class="table-scroll">
                            <table id="tabla-musculo" aria-label="Zonas musculares registradas">
                                <thead>
                                    <tr>
                                        <th scope="col">Zona / Músculo</th>
                                        <th scope="col">Tratamientos</th>
                                        <th scope="col">Descripción</th>
                                        <th scope="col">Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="musculo-tbody">
                                    <tr class="empty-row">
                                        <td colspan="4">Sin zonas registradas. Seleccione un músculo en el cuerpo.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div><!-- /musculo-right -->

            </div><!-- /musculo-layout -->

        </section><!-- /tab-musculo -->

    </main><!-- /main -->
    <!-- ═══════════════════════════════════════════
         MODAL — ELIMINAR REGISTRO
    ════════════════════════════════════════════ -->
    <div id="modal-eliminar" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-eliminar-title" hidden>
        <div class="modal-box">
            <header class="modal-header">
                <h2 id="modal-eliminar-title">🗑️ Eliminar Registro</h2>
                <button class="modal-close" id="modal-eliminar-close" type="button" aria-label="Cerrar modal">✕</button>
            </header>

            <div class="modal-body">
                <div class="modal-search-wrap">
                    <input id="modal-search-input" type="text" placeholder="Buscar por paciente o motivo de cita…" autocomplete="off" aria-label="Buscar registro a eliminar" />
                    <span class="icon" aria-hidden="true">🔍</span>
                </div>

                <div class="table-wrap" style="margin-top:12px">
                    <div class="table-scroll">
                        <table id="tabla-modal-resultados" aria-label="Resultados de búsqueda para eliminar">
                            <thead>
                                <tr>
                                    <th scope="col">Núm.</th>
                                    <th scope="col">Paciente</th>
                                    <th scope="col">Motivo de Cita</th>
                                    <th scope="col">Seleccionar</th>
                                </tr>
                            </thead>
                            <tbody id="modal-resultados-tbody">
                                <tr class="empty-row"><td colspan="4">Ingrese un término de búsqueda.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════
         MODAL — CONFIRMACIÓN DE ELIMINACIÓN
    ════════════════════════════════════════════ -->
    <div id="modal-confirmar" class="modal-overlay" role="alertdialog" aria-modal="true" aria-labelledby="modal-confirmar-title" hidden>
        <div class="modal-box modal-box-sm">
            <div class="modal-confirm-icon" aria-hidden="true">⚠️</div>
            <h2 id="modal-confirmar-title">¿Eliminar registro?</h2>
            <p id="modal-confirmar-msg" class="modal-confirm-msg"></p>
            <div class="modal-confirm-actions">
                <button id="btn-confirmar-cancelar" class="btn-secondary" type="button">Cancelar</button>
                <button id="btn-confirmar-eliminar" class="btn-danger" type="button">Sí, eliminar</button>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════
         MODAL — EDITAR REGISTRO DIAGNÓSTICO
    ════════════════════════════════════════════ -->
    <div id="modal-editar" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-editar-title" hidden>
        <div class="modal-box">
            <header class="modal-header">
                <h2 id="modal-editar-title">✏️ Editar Registro</h2>
                <button class="modal-close" id="modal-editar-close" type="button" aria-label="Cerrar modal">✕</button>
            </header>
            <div class="modal-body">
                <div class="edit-grid">
                    <div class="field-group">
                        <label for="edit-tipo">Tipo de Diagnóstico</label>
                        <select id="edit-tipo">
                            <option value="generico">Genérico</option>
                            <option value="especifico">Específico</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label for="edit-nombre">Nombre del Diagnóstico</label>
                        <input id="edit-nombre" type="text" maxlength="120" />
                    </div>
                    <div class="field-group">
                        <label for="edit-lesion">Nombre de Lesión</label>
                        <input id="edit-lesion" type="text" maxlength="80" />
                    </div>
                    <div class="field-group">
                        <label for="edit-dolor">Escala de Dolor</label>
                        <select id="edit-dolor">
                            <option value="Sin Dolor">Sin Dolor</option>
                            <option value="Leve">Leve</option>
                            <option value="Moderado">Moderado</option>
                            <option value="Fuerte">Fuerte</option>
                            <option value="Extremo">Extremo</option>
                        </select>
                    </div>
                    <div class="field-group" style="grid-column:1/-1">
                        <label for="edit-desc">Descripción</label>
                        <textarea id="edit-desc" rows="3" maxlength="500"></textarea>
                    </div>
                </div>
                <div class="modal-confirm-actions" style="margin-top:16px">
                    <button id="btn-editar-cancelar" class="btn-secondary" type="button">Cancelar</button>
                    <button id="btn-editar-guardar" class="btn-save" type="button">Guardar cambios</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/Content/diagnostico.js"></script>
</body>
</html>



